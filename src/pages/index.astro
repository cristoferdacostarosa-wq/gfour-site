---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProvaAutoridade from '../components/ProvaAutoridade.astro';
import Produtos from '../components/Produtos.astro';
import Footer from '../components/Footer.astro';

const tituloPagina = 'G-Four | Fibras Estruturais para Concreto - 25 Anos de Expertise';
const descricaoPagina = 'Referência nacional em macrofibra estrutural e microfibra para concreto. Substitua a tela de aço com economia de até 40% e desempenho técnico superior. +6 milhões de m² executados.';
---

<Layout title={tituloPagina} description={descricaoPagina}>
  <Header />
  <main>
    <Hero />
    <ProvaAutoridade />
    <Produtos />
  </main>
  <Footer />
</Layout>