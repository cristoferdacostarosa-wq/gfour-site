---
const whatsappNumero = '5548996228397';
const whatsappMensagem = 'Olá! Vim pelo site da G-Four e gostaria de mais informações sobre as fibras estruturais.';
const whatsappLink = `https://wa.me/${whatsappNumero}?text=${encodeURIComponent(whatsappMensagem)}`;

const selos = [
  { titulo: '+6 MILHÕES m²', descricao: 'de piso executado' },
  { titulo: 'PRODUTO ÚNICO', descricao: 'no mercado brasileiro' },
  { titulo: 'ATÉ 40%', descricao: 'de economia vs tela de aço' },
];
---

<section class="relative min-h-[calc(100vh-80px)] flex items-center overflow-hidden">

  <div class="absolute inset-0 z-0">
    <img src="/images/piso-polido-galpao-industrial.jpg" alt="Piso industrial de concreto polido com fibras estruturais G-Four em galpão" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-gfour-verde-escuro/95 via-gfour-verde-escuro/85 to-gfour-verde-escuro/70"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-gfour-verde-escuro/40"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 md:px-8 py-20 md:py-28 w-full">

    <div class="max-w-3xl">

      <p class="text-gfour-branco-off text-xs md:text-sm font-bold uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
        <span class="inline-block w-12 h-px bg-gfour-branco-off"></span>
        Fibras estruturais para concreto
      </p>

      <h1 class="text-gfour-branco text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight mb-6">
        25 anos estruturando o concreto do <span class="text-gfour-branco">Brasil.</span>
      </h1>

      <p class="text-gfour-branco-off text-lg md:text-xl leading-relaxed mb-10 max-w-2xl opacity-90">
        Fibras estruturais que substituem a tela de aço com economia de até 40% e desempenho técnico superior. Referência nacional desde 2014.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-12">

        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="group bg-gfour-branco text-gfour-verde px-8 py-4 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-gfour-branco-off transition-all shadow-xl hover:shadow-2xl hover:-translate-y-0.5 inline-flex items-center justify-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/></svg>
          Falar com Especialista
        </a>

        <a href="/economia" class="group border-2 border-gfour-branco text-gfour-branco px-8 py-4 rounded-md font-bold text-sm uppercase tracking-wide hover:bg-gfour-branco hover:text-gfour-verde transition-all inline-flex items-center justify-center gap-2">
          Ver Comparativo Técnico
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="relative z-10 bg-gfour-verde-escuro/60 backdrop-blur-sm border-t border-gfour-branco/10">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-6 md:py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {selos.map((selo) => (
          <div class="flex items-center gap-4 md:justify-center">
            <div class="w-1 h-12 bg-gfour-branco"></div>
            <div>
              <p class="text-gfour-branco font-bold text-xl md:text-2xl tracking-tight leading-none">{selo.titulo}</p>
              <p class="text-gfour-branco-off text-xs md:text-sm opacity-80 mt-1">{selo.descricao}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>