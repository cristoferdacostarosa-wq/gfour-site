---
const contato = {
  whatsappComercial: { numero: '5548996228397', exibicao: '(48) 99622-8397' },
  email: 'guilherme.gfourengenharia@gmail.com',
  endereco: 'Rua Ambrosio de Carvalho, 178 - Jaraguá 99',
  cidade: 'Jaraguá do Sul / SC',
  cep: 'CEP 89260-646',
};

const redesSociais = {
  instagram: 'https://www.instagram.com/gfourfibras/',
  linkedin: 'https://www.linkedin.com/company/107902082',
};

const whatsappMensagem = 'Olá! Vim pelo site da G-Four e gostaria de mais informações sobre as fibras estruturais.';
const whatsappLink = `https://wa.me/${contato.whatsappComercial.numero}?text=${encodeURIComponent(whatsappMensagem)}`;

const itensMenu = [
  { nome: 'Home', link: '/' },
  { nome: 'Produtos', link: '/produtos' },
  { nome: 'Cases', link: '/cases' },
  { nome: 'Economia', link: '/economia' },
  { nome: 'Contato', link: '/contato' },
];

const anoAtual = new Date().getFullYear();
---

<footer class="bg-gfour-verde-escuro text-gfour-branco-off mt-auto">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-12 md:py-16">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

      <div>
      <a href="/" class="inline-block mb-4" aria-label="G-Four">
        <img src="/logos/gfour-texto-branco.svg" alt="G-Four" class="h-16 w-auto" />
      </a>
        <p class="text-sm font-medium text-gfour-branco mb-4">Na estrutura de tudo que importa.</p>
        <p class="text-sm leading-relaxed opacity-80">Referência nacional em fibras estruturais para concreto desde 2014. 25 anos de expertise técnica aplicada em obra.</p>
      </div>

      <div>
        <h3 class="text-gfour-branco font-bold text-sm uppercase tracking-wider mb-4">Contato</h3>

        <ul class="space-y-3 text-sm">
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-gfour-branco transition-colors inline-flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488"/></svg>
              {contato.whatsappComercial.exibicao}
            </a>
          </li>
          <li>
            <a href={`mailto:${contato.email}`} class="hover:text-gfour-branco transition-colors inline-flex items-center gap-2 break-all">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <span>{contato.email}</span>
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <div>
              <p>{contato.endereco}</p>
              <p>{contato.cidade}</p>
              <p>{contato.cep}</p>
            </div>
          </li>
        </ul>

        <div class="mt-6 flex gap-4">
          <a href={redesSociais.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-gfour-branco-off hover:text-gfour-branco transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href={redesSociais.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gfour-branco-off hover:text-gfour-branco transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-gfour-branco font-bold text-sm uppercase tracking-wider mb-4">Navegação</h3>
        <ul class="space-y-2 text-sm">
          {itensMenu.map((item) => (
            <li><a href={item.link} class="hover:text-gfour-branco transition-colors">{item.nome}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-12 pt-8 border-t border-gfour-verde-claro/30">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs opacity-70">
        <p>© {anoAtual} G-Four Fibras Estruturais. Todos os direitos reservados.</p>
        <p>Engenharia é fazer o necessário com o necessário.</p>
      </div>
    </div>

  </div>
</footer>